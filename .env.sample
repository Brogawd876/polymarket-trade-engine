TICKER=polymarket
MARKET_ASSET=btc
PRIVATE_KEY=
# Type 3 is the proven live account model for this owner.
# Derive the deposit wallet from PRIVATE_KEY owner with @polymarket/builder-relayer-client deriveDepositWallet(...).
# The address below is specific to owner 0x3528764a45bB13eC6BD8Deb1a73b5034742E6329; do not copy it for another wallet.
# Never reuse the disproven funders 0xbcbae6BE8cE9AD38C4FFD71254202f2aA27a30CF or 0x609df252DF1371DBABD7aA234e028ACe9EAd90A2.
POLY_FUNDER_ADDRESS=0x9bB7C3aafCeb82665293f9cd784F61112fFa4c51
POLY_SIGNATURE_TYPE=3 # 0=EOA, 1=POLY_PROXY (Magic), 2=POLY_GNOSIS_SAFE, 3=POLY_1271
POLY_API_KEY_NONCE=1

# Static CLOB credentials are intentionally left blank. Production CLOB auth derives fresh credentials
# from PRIVATE_KEY; BUILDER_* is only for wrap/unwrap/redeem relayer operations.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional: required only for wrap/unwrap/redeem via relayer
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

MARKET_WINDOW=5m
FORCE_PROD=false
MAX_SESSION_LOSS=3
WALLET_BALANCE=50
