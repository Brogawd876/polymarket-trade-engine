# Operator Cockpit — Environment Variables
#
# Copy this file to .env.local and set real values there.
# NEVER commit .env.local or any file containing real tokens to git.
#
# The token is only used in the browser to call /api/operator/* endpoints.
# It does NOT expose signing keys, wallet keys, or trading credentials.

# REST base URL for the backend (no trailing slash).
# Default: http://127.0.0.1:3000
VITE_API_BASE_URL=http://127.0.0.1:3000

# WebSocket telemetry URL.
# Default: derived from VITE_API_BASE_URL (ws://127.0.0.1:3000/telemetry)
VITE_WS_URL=ws://127.0.0.1:3000/telemetry

# Optional operator auth token.
# Mirrors backend env var OPERATOR_AUTH_TOKEN.
# If set, the UI will send: Authorization: Bearer <token>
# on all /api/operator/* requests.
# Leave blank if the backend does not require auth.
VITE_OPERATOR_AUTH_TOKEN=
